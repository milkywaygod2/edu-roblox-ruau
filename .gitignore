############################################
# Explicit ignores override the whitelist.

# Secrets and local credentials
**/.env
**/.env.*
**/secrets.*
**/credentials.*
**/.credentials.json
**/auth.json
**/config.toml
**/*.key
**/*.pem
**/*.p12
**/*.jks
**/token*

# Roblox generated dependencies and caches
**/Packages/
**/_Index/
**/sourcemap.json
**/*.sourcemap.json
**/*.rbxl.lock
**/*.rbxlx.lock
**/.luau-lsp/
**/.lune/
**/.rojo/
**/node_modules/
**/coverage/
**/*.lcov

# Build and temporary files
**/build/
**/dist/
**/out/
**/temp/
**/tmp/
**/*.log
**/*.tmp

# OS and editor noise
**/.DS_Store
**/Thumbs.db